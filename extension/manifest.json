{
  "manifest_version": 3,
  "name": "LocalPro Job Importer",
  "version": "1.1.0",
  "description": "Scan and import job posts from Facebook, LinkedIn, JobStreet, and Indeed into LocalPro.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "LocalPro Job Importer"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.facebook.com/*",
        "*://*.linkedin.com/*",
        "*://*.jobstreet.com/*",
        "*://*.jobstreet.com.ph/*",
        "*://*.indeed.com/*",
        "*://*.ph.indeed.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "*://*.facebook.com/*",
    "*://*.linkedin.com/*",
    "*://*.jobstreet.com/*",
    "*://*.jobstreet.com.ph/*",
    "*://*.indeed.com/*",
    "*://*.ph.indeed.com/*",
    "https://*.localpro.asia/*",
    "https://www.localpro.asia/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["styles.css"],
      "matches": [
        "*://*.facebook.com/*",
        "*://*.linkedin.com/*",
        "*://*.jobstreet.com/*",
        "*://*.jobstreet.com.ph/*",
        "*://*.indeed.com/*",
        "*://*.ph.indeed.com/*"
      ]
    }
  ]
}
