# dependencies
/node_modules

# build output (generated by npm run build)
/dist/content.js
/dist/background.js
/dist/popup.js

# keep dist HTML/CSS/manifest in source control
# so they can be loaded without building

# environment / secrets
.env
.env.*
*.pem
*.key

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini

# editor / IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# TypeScript cache
*.tsbuildinfo
