{
  "manifest_version": 3,
  "name": "LocalPro Lead Engine",
  "version": "2.0.0",
  "description": "AI-powered lead engine that captures, classifies, and auto-matches service requests from Facebook Marketplace, Google Business, FB Groups, and Messenger to providers.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "LocalPro Lead Engine"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.facebook.com/*",
        "*://*.messenger.com/*",
        "*://*.google.com/*",
        "*://*.google.com.ph/*",
        "*://*.maps.google.com/*",
        "*://*.business.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "*://*.facebook.com/*",
    "*://*.messenger.com/*",
    "*://*.google.com/*",
    "*://*.google.com.ph/*",
    "*://*.maps.google.com/*",
    "*://*.business.google.com/*",
    "https://*.localpro.asia/*",
    "https://www.localpro.asia/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["styles.css"],
      "matches": [
        "*://*.facebook.com/*",
        "*://*.messenger.com/*",
        "*://*.google.com/*",
        "*://*.google.com.ph/*",
        "*://*.maps.google.com/*",
        "*://*.business.google.com/*"
      ]
    }
  ]
}
